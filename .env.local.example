###> Client config — copy to .env.local and edit ###

APP_ENV=prod
APP_SECRET=CHANGE_ME_WITH_A_RANDOM_STRING

# MariaDB — change db name, user, password per client
DATABASE_URL="mysql://app:app@db:3306/blog_web?serverVersion=mariadb-11.0.0&charset=utf8mb4"

# Mailer — Brevo SMTP (remplacer LOGIN et CLE_SMTP par vos identifiants)
# Le @ du login doit être encodé en %40
MAILER_DSN=brevo+smtp://LOGIN%40smtp-brevo.com:CLE_SMTP@default

# reCAPTCHA v3 — obtenir sur https://www.google.com/recaptcha/admin (type v3)
RECAPTCHA_SITE_KEY=6Le...votre_cle_site
RECAPTCHA_SECRET_KEY=6Le...votre_cle_secrete

###< Client config ###
