{% extends 'base.html.twig' %}

{% block title %}Abonnement confirme — {{ site.name|default('Blog&Web') }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">

            <div class="card border-0 shadow-sm p-5">
                <div class="mb-4">
                    <i class="fas fa-check-circle text-success" style="font-size: 4rem;"></i>
                </div>
                <h1 class="h3 mb-3">Abonnement confirme !</h1>
                <p class="text-muted mb-4">
                    Merci ! Vous recevrez desormais nos actualites a l'adresse
                    <strong>{{ subscriber.email }}</strong>.
                </p>
                <p class="small text-muted mb-4">
                    Vous pouvez modifier vos preferences ou vous desabonner a tout moment
                    depuis le lien present dans chaque email.
                </p>
                <a href="{{ path('app_home') }}" class="btn btn-primary">
                    <i class="fas fa-home me-1"></i> Retour a l'accueil
                </a>
            </div>

        </div>
    </div>
</div>
{% endblock %}
