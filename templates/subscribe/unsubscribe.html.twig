{% extends 'base.html.twig' %}

{% block title %}Desabonnement — {{ site.name|default('Blog&Web') }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">

            <div class="card border-0 shadow-sm p-5">
                <div class="mb-4">
                    <i class="fas fa-envelope-open text-muted" style="font-size: 4rem;"></i>
                </div>
                <h1 class="h3 mb-3">Desabonnement effectue</h1>
                <p class="text-muted mb-4">
                    Vous ne recevrez plus d'emails de notre part a l'adresse
                    <strong>{{ subscriber.email }}</strong>.
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="{{ resubscribe_url }}" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-undo me-1"></i> Se reabonner
                    </a>
                    <a href="{{ path('app_home') }}" class="btn btn-primary btn-sm">
                        <i class="fas fa-home me-1"></i> Accueil
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
