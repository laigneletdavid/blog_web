{% extends 'base.html.twig' %}

{% block title %}Mes abonnements — {{ site.name|default('Blog&Web') }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h3 mb-2">Mes abonnements</h1>
                    <p class="text-muted mb-4">
                        Gerez vos preferences de notification pour
                        <strong>{{ subscriber.email }}</strong>.
                    </p>

                    {{ form_start(form, { attr: { class: 'needs-validation', novalidate: 'novalidate' } }) }}

                        <div class="mb-3">
                            {{ form_row(form.email) }}
                        </div>

                        {% if form.subscribeArticles is defined or form.subscribeEvents is defined %}
                            <hr class="my-3">
                            <h2 class="h6 mb-3">Je souhaite recevoir :</h2>

                            {% if form.subscribeArticles is defined %}
                                <div class="form-check mb-2">
                                    {{ form_widget(form.subscribeArticles) }}
                                    {{ form_label(form.subscribeArticles) }}
                                </div>
                            {% endif %}
                            {% if form.subscribeEvents is defined %}
                                <div class="form-check mb-2">
                                    {{ form_widget(form.subscribeEvents) }}
                                    {{ form_label(form.subscribeEvents) }}
                                </div>
                            {% endif %}
                        {% endif %}

                        {# Honeypot #}
                        {{ form_widget(form.website) }}

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a href="{{ unsubscribe_url }}" class="btn btn-outline-danger btn-sm">
                                <i class="fas fa-times me-1"></i> Tout desabonner
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i> Enregistrer
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
