{% set menus = menu_service.findMenuTwig %}
{% set widget_articles = widget_service.findLastArticle %}
{% set widget_article = widget_articles['0'] | default(null) %}
{% set categories = widget_service.findCategories %}


<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>Blog&Web</title>
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('images/apple-touch-icon.png') }}">
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('images/favicon-32x32.png') }}">
        <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('images/favicon-16x16.png') }}">
        <link rel="manifest" href="{{ asset('images/site.webmanifest') }}">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body>

        {# ====== HEADER ====== #}
        <header class="header">
            {# Admin bar #}
            {% if is_granted('ROLE_CORRECTOR') %}
            <div class="admin-bar">
                <div class="container d-flex align-items-center gap-2 py-1">
                    <img src="{{ asset('images/logo xlight- b&w-50px.png') }}" alt="Admin" style="height: 20px;"/>
                    <a href="{{ path('admin') }}">Administration</a>
                </div>
            </div>
            {% endif %}

            {# Desktop header #}
            <div class="header-main desk">
                <div class="container d-flex align-items-center justify-content-between">
                    <a href="{{ path('app_home') }}" class="header-logo">
                        <img src="{{ asset('images/BlogWebbeta-h150.png') }}" alt="Blog&Web"/>
                    </a>

                    <nav class="header-nav d-flex align-items-center gap-1">
                        <a href="{{ path('app_home') }}" class="nav-link">Accueil</a>
                        {% for menu in menus %}
                            {% if menu.children|length > 0 %}
                                <div class="dropdown">
                                    <a class="nav-link dropdown-toggle" href="{{ menu|menuLink }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        {{ menu.name }}
                                    </a>
                                    <ul class="dropdown-menu">
                                        {% for child in menu.children %}
                                            {% if child.isVisible %}
                                                <li><a class="dropdown-item" href="{{ child|menuLink }}">{{ child.name }}</a></li>
                                            {% endif %}
                                        {% endfor %}
                                    </ul>
                                </div>
                            {% else %}
                                <a href="{{ menu|menuLink }}" class="nav-link">{{ menu.name }}</a>
                            {% endif %}
                        {% endfor %}
                        <a href="{{ path('app_contact') }}" class="nav-link">Contact</a>
                    </nav>

                    <div class="header-actions d-flex align-items-center gap-2">
                        <div class="header-search dropdown" data-controller="search">
                            <form class="d-flex align-items-center gap-2" action="{{ path('app_search') }}" method="get" data-search-target="form" data-action="search#doSearch:prevent">
                                <input type="search" name="q" class="form-control form-control-sm search-input" placeholder="Rechercher..." aria-label="Search" data-search-target="q" autocomplete="off">
                                <button class="btn btn-sm btn-outline-primary" type="submit">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                                    </svg>
                                </button>
                            </form>
                            <div class="dropdown-menu" data-search-target="results">
                                <a class="dropdown-item" href="#">Contenu</a>
                            </div>
                        </div>

                        {% if app.user %}
                            <a class="btn btn-sm btn-primary" href="{{ path('app_user_show', { 'id': app.user.id}) }}">Mon compte</a>
                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_logout')}}">Deconnexion</a>
                        {% else %}
                            <a class="btn btn-sm btn-primary" href="{{ path('app_login')}}">Connexion</a>
                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_register')}}">Inscription</a>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Mobile header #}
            <div class="header-mobile smart">
                <div class="container d-flex align-items-center justify-content-between py-2">
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar" aria-label="Toggle navigation">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/>
                        </svg>
                    </button>
                    <a href="{{ path('app_home') }}" class="header-logo">
                        <img src="{{ asset('images/BlogWebbeta-h150.png') }}" alt="Blog&Web"/>
                    </a>
                    <div></div>{# spacer for flex balance #}
                </div>

                <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
                    <div class="offcanvas-header">
                        <img src="{{ asset('images/BlogWebbeta-h150.png') }}" alt="Blog&Web" style="height: 36px; width: auto;">
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                    </div>
                    <div class="offcanvas-body">
                        <div class="header-search dropdown mb-4" data-controller="search">
                            <form class="d-flex gap-2" action="{{ path('app_search') }}" method="get" data-search-target="form" data-action="search#doSearch:prevent">
                                <input type="search" name="q" class="form-control" placeholder="Rechercher..." aria-label="Search" data-search-target="q" autocomplete="off">
                                <button class="btn btn-outline-primary" type="submit">Chercher</button>
                            </form>
                            <div class="dropdown-menu" data-search-target="results">
                                <a class="dropdown-item" href="#">Contenu</a>
                            </div>
                        </div>

                        <ul class="navbar-nav flex-grow-1 mb-4">
                            <li class="nav-item"><a href="{{ path('app_home') }}" class="nav-link">Accueil</a></li>
                            {% for menu in menus %}
                                {% if menu.children|length > 0 %}
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle" href="{{ menu|menuLink }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            {{ menu.name }}
                                        </a>
                                        <ul class="dropdown-menu">
                                            {% for child in menu.children %}
                                                {% if child.isVisible %}
                                                    <li><a class="dropdown-item" href="{{ child|menuLink }}">{{ child.name }}</a></li>
                                                {% endif %}
                                            {% endfor %}
                                        </ul>
                                    </li>
                                {% else %}
                                    <li class="nav-item"><a href="{{ menu|menuLink }}" class="nav-link">{{ menu.name }}</a></li>
                                {% endif %}
                            {% endfor %}
                            <li class="nav-item"><a href="{{ path('app_contact') }}" class="nav-link">Contact</a></li>
                        </ul>

                        <div class="d-grid gap-2">
                            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                <a href="{{ path('app_user_show', {'id': app.user.id}) }}" class="btn btn-primary">Mon profil</a>
                                <a href="{{ path('app_logout') }}" class="btn btn-outline-secondary">Se deconnecter</a>
                            {% else %}
                                <a href="{{ path('app_login') }}" class="btn btn-primary">Se connecter</a>
                                <a href="{{ path('app_register') }}" class="btn btn-outline-primary">Creer un compte</a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </header>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="container mt-3">
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}

        {# ====== FOOTER ====== #}
        <footer class="footer">
            <div class="container py-5">
                <div class="row">
                    {# Col 1 : Logo + tagline #}
                    <div class="col-lg-4 mb-4 mb-lg-0">
                        <a href="{{ path('app_home') }}" class="footer-logo d-inline-block mb-2">
                            <img src="{{ asset('images/BlogWebbeta - blanc.png') }}" alt="Blog&Web"/>
                        </a>
                        <p class="footer-tagline">Votre CMS professionnel, simple et accessible. Accompagne par un expert du web.</p>
                        <div class="footer-social d-flex gap-2 mt-3">
                            <a href="#" class="social-icon" aria-label="Facebook">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"/>
                                </svg>
                            </a>
                            <a href="#" class="social-icon" aria-label="Instagram">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"/>
                                </svg>
                            </a>
                        </div>
                    </div>

                    {# Col 2 : Navigation #}
                    <div class="col-lg-4 mb-4 mb-lg-0">
                        <h6 class="footer-section">Navigation</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item"><a href="{{ path('app_home') }}" class="nav-link">Accueil</a></li>
                            <li class="nav-item"><a href="{{ path('app_article_show_all') }}" class="nav-link">Blog</a></li>
                            <li class="nav-item"><a href="{{ path('app_contact') }}" class="nav-link">Contact</a></li>
                            <li class="nav-item"><a href="#" class="nav-link">Aide & assistance</a></li>
                        </ul>
                    </div>

                    {# Col 3 : Legal #}
                    <div class="col-lg-4">
                        <h6 class="footer-section">Informations</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item"><a href="#" class="nav-link">Mentions legales</a></li>
                            <li class="nav-item"><a href="#" class="nav-link">Confidentialite & Cookies</a></li>
                        </ul>
                    </div>
                </div>
                <div class="footer-bottom pt-4 mt-4">
                    <span>&copy; {{ "now"|date("Y") }} {% block title_page %}Blog&Web{% endblock %} &mdash; Tous droits reserves</span>
                </div>
            </div>
        </footer>

    </body>
</html>
