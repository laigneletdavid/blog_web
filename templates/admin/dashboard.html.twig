{% extends '@EasyAdmin/page/content.html.twig' %}

{% set url_site = ea_url()
    .setController('App\\Controller\\Admin\\SiteCrudController')
    .setAction('index') %}

{% set url_page = ea_url()
    .setController('App\\Controller\\Admin\\PageCrudController')
    .setAction('index') %}

{% set url_blog = ea_url()
    .setController('App\\Controller\\Admin\\ArticleCrudController')
    .setAction('index') %}

{% set url_new_article = ea_url()
    .setController('App\\Controller\\Admin\\ArticleCrudController')
    .setAction('new') %}

{% set url_new_page = ea_url()
    .setController('App\\Controller\\Admin\\PageCrudController')
    .setAction('new') %}

{% block content_title %}
    <h1 class="title_admin">{{ title_admin }}</h1>
{% endblock %}

{% block main %}

    {# --- Raccourcis rapides --- #}
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <a href="{{ url_new_article }}" class="btn btn-primary w-100 py-3">
                <i class="fas fa-plus me-2"></i> Nouvel article
            </a>
        </div>
        <div class="col-6 col-lg-3">
            <a href="{{ url_new_page }}" class="btn btn-outline-primary w-100 py-3">
                <i class="fas fa-plus me-2"></i> Nouvelle page
            </a>
        </div>
    </div>

    {# --- Cards principales --- #}
    <div class="row g-4 pb-5 row-cols-1 row-cols-lg-3">
        {% if is_granted('ROLE_ADMIN') %}
            <div class="col-12 col-lg-4">
                <div class="feature d-flex flex-column justify-content-between h-100">
                    <div class="feature-icon d-inline-flex align-items-baseline justify-content-center fs-2 mb-3">
                        <i class="fa-fw fas fa-gear"></i>
                        <h3 class="fs-2 ps-1 feature-title">Identité du site</h3>
                    </div>
                    <p>Nom, coordonnées, logo : les informations essentielles de votre site.</p>
                    <a href="{{ url_site }}" class="btn-font-secondary btn btn-secondary">Modifier</a>
                </div>
            </div>
        {% endif %}
        <div class="col-12 col-lg-4">
            <div class="feature d-flex flex-column justify-content-between h-100">
                <div class="feature-icon d-inline-flex align-items-baseline justify-content-center fs-2 mb-3">
                    <i class="fa-fw fas fa-file"></i>
                    <h3 class="fs-2 ps-1 feature-title">Pages</h3>
                </div>
                <p>Gérez les pages de votre site web.</p>
                <a href="{{ url_page }}" class="btn-font-secondary btn btn-secondary">Voir les pages</a>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="feature d-flex flex-column justify-content-between h-100">
                <div class="feature-icon d-inline-flex align-items-baseline justify-content-center fs-2 mb-3">
                    <i class="fa-fw fas fa-newspaper"></i>
                    <h3 class="fs-2 ps-1 feature-title">Blog</h3>
                </div>
                <p>Publiez des articles pour vos visiteurs et votre référencement.</p>
                <a href="{{ url_blog }}" class="btn-font-secondary btn btn-secondary">Voir les articles</a>
            </div>
        </div>
    </div>

    {# --- Zone aide --- #}
    <div class="row">
        <div class="col-12 col-lg-4 offset-lg-8">
            <div class="content-color p-3 rounded">
                <h2 class="help-title"><i class="fa fa-question-circle me-2"></i>Aide</h2>
                <p class="mb-0">Retrouvez ici des astuces sur la gestion de votre site et les bases du référencement.</p>
            </div>
        </div>
    </div>

{% endblock %}
