        border: 1px solid #e2e8f0;
        border-radius: 10px !important;
        margin-bottom: 0.5rem;
        overflow: hidden;
    }
    .bw-guide .accordion-button {
        font-weight: 600;
        font-size: 0.92rem;
        padding: 0.875rem 1.125rem;
        background: #fff;
    }
    .bw-guide .accordion-button:not(.collapsed) {
        background: #f8fafc;
        color: #1e293b;
        box-shadow: none;
    }
    .bw-guide .accordion-button:focus {
        box-shadow: none;
        border-color: #e2e8f0;
    }
    .bw-guide .accordion-body {
        font-size: 0.875rem;
        line-height: 1.65;
        color: #475569;
        padding: 1.25rem;
    }
    .bw-guide .accordion-body h5 {
        font-size: 0.92rem;
        font-weight: 600;
        color: #1e293b;
        margin: 1.25rem 0 0.5rem;
    }
    .bw-guide .accordion-body h5:first-child {
        margin-top: 0;
    }
    .bw-guide-tip {
        padding: 0.75rem 1rem;
        background: #fffbeb;
        border-left: 3px solid #f59e0b;
        border-radius: 0 8px 8px 0;
        margin: 1rem 0 0;
        font-size: 0.84rem;
    }
</style>
{% endblock %}
