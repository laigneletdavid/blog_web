{% extends 'base.html.twig' %}

{% block body %}
<section class="restricted-access py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="restricted-card text-center">
                    <div class="restricted-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </div>

                    <h1 class="restricted-title">Contenu restreint</h1>

                    {% if visibility == 'user' %}
                        <p class="restricted-message">
                            Cette page est reservee aux membres du site.
                            Connectez-vous ou creez un compte pour y acceder.
                        </p>
                    {% elseif visibility == 'author' %}
                        <p class="restricted-message">
                            Cette page est reservee aux auteurs et contributeurs du site.
                        </p>
                    {% elseif visibility == 'admin' %}
                        <p class="restricted-message">
                            Cette page est reservee aux administrateurs.
                        </p>
                    {% else %}
                        <p class="restricted-message">
                            Vous n'avez pas les droits necessaires pour acceder a ce contenu.
                        </p>
                    {% endif %}

                    {% if not app.user %}
                        <div class="restricted-actions">
                            <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
                                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                                    <polyline points="10 17 15 12 10 7"/>
                                    <line x1="15" y1="12" x2="3" y2="12"/>
                                </svg>
                                Se connecter
                            </a>
                            <a href="{{ path('app_register') }}" class="btn btn-outline-primary btn-lg">
                                Creer un compte
                            </a>
                        </div>
                    {% elseif visibility in ['author', 'admin'] %}
                        <p class="restricted-info text-muted mt-3">
                            Vous etes connecte mais votre compte ne dispose pas des droits suffisants pour ce contenu.
                        </p>
                    {% endif %}

                    <a href="{{ path('app_home') }}" class="restricted-back">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1">
                            <line x1="19" y1="12" x2="5" y2="12"/>
                            <polyline points="12 19 5 12 12 5"/>
                        </svg>
                        Retour a l'accueil
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
