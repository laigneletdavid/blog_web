{# Widget "Prochains événements" pour sidebar
   Variable : upcomingEvents (Event[]) #}
{% if upcomingEvents|default([])|length > 0 %}
<div class="widget-events">
    <h4 class="widget-events__title">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Prochains événements
    </h4>
    <ul class="widget-events__list">
        {% for event in upcomingEvents %}
        <li class="widget-events__item">
            <a href="{{ path('app_event_show', { slug: event.slug }) }}" class="widget-events__link">
                <div class="widget-events__date">
                    <span class="widget-events__day">{{ event.dateStart|date('d') }}</span>
                    <span class="widget-events__month">{{ event.dateStart|date('M') }}</span>
                </div>
                <div class="widget-events__info">
                    <span class="widget-events__event-title">{{ event.title }}</span>
                    {% if event.location %}
                    <span class="widget-events__location">{{ event.location }}</span>
                    {% endif %}
                </div>
            </a>
        </li>
        {% endfor %}
    </ul>
    <a href="{{ path('app_event_index') }}" class="widget-events__all">
        Voir tous les événements →
    </a>
</div>
{% endif %}
