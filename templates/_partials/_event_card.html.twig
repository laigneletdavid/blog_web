{# Card événement réutilisable
   Variables : event (Event), isPast (bool, optionnel) #}
{% set isPast = isPast|default(false) %}

<a href="{{ path('app_event_show', { slug: event.slug }) }}" class="event-card {{ isPast ? 'event-card--past' : '' }}">
    {% if event.image %}
    <div class="event-card__img">
        <img src="{{ asset('documents/medias/' ~ event.image.fileName) }}"
             alt="{{ event.title }}"
             loading="lazy">
    </div>
    {% endif %}

    <div class="event-card__body">
        <div class="event-card__date">
            <span class="event-card__date-day">{{ event.dateStart|date('d') }}</span>
            <span class="event-card__date-month">{{ event.dateStart|date('M') }}</span>
            {% if event.multiDay %}
            <span class="event-card__date-range">→ {{ event.dateEnd|date('d M') }}</span>
            {% endif %}
        </div>

        <div class="event-card__content">
            <h3 class="event-card__title">{{ event.title }}</h3>

            {% if event.location %}
            <span class="event-card__location">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {{ event.location }}
            </span>
            {% endif %}

            {% if event.shortDescription %}
            <p class="event-card__excerpt">{{ event.shortDescription|length > 120 ? event.shortDescription|slice(0, 120) ~ '…' : event.shortDescription }}</p>
            {% endif %}

            <span class="event-card__time">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {{ event.dateStart|date('H:i') }}
                {% if event.dateEnd %} — {{ event.dateEnd|date('H:i') }}{% endif %}
            </span>
        </div>
    </div>

    {% if isPast %}
    <div class="event-card__badge">Terminé</div>
    {% endif %}
</a>
