{# Badge panier — a inclure dans les headers de chaque theme #}
{% if site_context is defined and site_context.hasModule('ecommerce') %}
<a href="{{ path('app_cart') }}" class="cart-badge-link position-relative" data-controller="cart-badge" data-cart-badge-url-value="{{ path('app_cart_count') }}" title="Panier">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    </svg>
    <span class="cart-badge-count badge rounded-pill bg-primary" data-cart-badge-target="count" style="display:none;">0</span>
</a>
{% endif %}
