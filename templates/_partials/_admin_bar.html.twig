{# ====== ADMIN BAR — Commun à tous les thèmes ====== #}
{# Affiché uniquement pour les utilisateurs avec ROLE_AUTHOR+ #}
{% if is_granted('ROLE_AUTHOR') %}
<div class="admin-bar">
    <div class="container d-flex align-items-center justify-content-between py-1">
        <div class="d-flex align-items-center gap-2">
            <img src="{{ asset('images/logo xlight- b&w-50px.png') }}" alt="Admin" style="height: 20px;"/>
            <a href="{{ path('admin') }}">Administration</a>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="admin-bar__user">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                {{ app.user.firstName is defined and app.user.firstName ? app.user.firstName ~ ' ' ~ app.user.name|default('') : app.user.email }}
            </span>
            <a href="{{ path('app_logout') }}" class="admin-bar__logout" title="Se déconnecter">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Déconnexion
            </a>
        </div>
    </div>
</div>
{% endif %}
