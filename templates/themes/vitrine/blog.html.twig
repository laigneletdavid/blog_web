{# ====== BLOG — Theme Vitrine ====== #}
{# Layout: Grille 2 colonnes pleine largeur sans sidebar, clean #}

<div class="container">
    <nav aria-label="breadcrumb" class="my-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
            <li class="breadcrumb-item active">{{ title_page }}</li>
        </ol>
    </nav>

    <h1 class="vit-blog__title">{{ title_page }}</h1>

    {% if filterMonth is defined and filterMonth %}
    <div class="mb-4">
        <a href="{{ path('app_article_show_all') }}" class="btn btn-outline-secondary btn-sm">&times; Tous les articles</a>
    </div>
    {% endif %}

    {% set baseParams = {} %}
    {% if filterMonth is defined and filterMonth %}
        {% set baseParams = baseParams|merge({ month: filterMonth, year: filterYear }) %}
    {% endif %}

    {# Grille 2 colonnes #}
    {% if articles|length > 0 %}
    <div class="row g-4 mb-5">
        {% for article in articles %}
        <div class="col-md-6">
            <div class="vit-blog-card">
                {% if article.featuredMedia %}
                <a href="{{ path('app_article_show', {slug: article.slug}) }}">
                    <img src="{{ asset('documents/medias/' ~ (article.featuredMedia.webpFileName ?? article.featuredMedia.fileName)) }}" alt="{{ article.title }}" class="vit-blog-card__img" loading="lazy"/>
                </a>
                {% endif %}
                <div class="vit-blog-card__body">
                    {% if article.categories|length > 0 %}
                    <span class="vit-blog-card__cat">{{ article.categories|first.name }}</span>
                    {% endif %}
                    <h2 class="vit-blog-card__title">
                        <a href="{{ path('app_article_show', {slug: article.slug}) }}">{{ article.title }}</a>
                    </h2>
                    <p class="vit-blog-card__excerpt">{{ article.content|striptags|slice(0, 150) }}...</p>
                    <div class="vit-blog-card__meta">
                        {% if article.publishedAt %}<span>{{ article.publishedAt|date('d M Y') }}</span>{% endif %}
                        <span>{{ article.content|readingTime }} min</span>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <p class="text-muted">Aucun article pour cette periode.</p>
    {% endif %}

    {# Pagination #}
    {% if totalPages > 1 %}
    <nav aria-label="Pagination" class="mb-5">
        <ul class="pagination justify-content-center">
            <li class="page-item {{ currentPage <= 1 ? 'disabled' : '' }}">
                <a class="page-link" href="{{ path('app_article_show_all', baseParams|merge({ page: currentPage - 1 })) }}">&laquo;</a>
            </li>
            {% for p in 1..totalPages %}
            <li class="page-item {{ p == currentPage ? 'active' : '' }}">
                <a class="page-link" href="{{ path('app_article_show_all', baseParams|merge({ page: p })) }}">{{ p }}</a>
            </li>
            {% endfor %}
            <li class="page-item {{ currentPage >= totalPages ? 'disabled' : '' }}">
                <a class="page-link" href="{{ path('app_article_show_all', baseParams|merge({ page: currentPage + 1 })) }}">&raquo;</a>
            </li>
        </ul>
    </nav>
    {% endif %}
</div>
