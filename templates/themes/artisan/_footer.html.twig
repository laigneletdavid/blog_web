{# ====== FOOTER — Theme Artisan ====== #}
{# Style: Centre, chaleureux, focus contact #}
<footer class="footer footer--artisan">
    <div class="container py-5">
        <div class="row">
            <div class="col-lg-4 mb-4 mb-lg-0 text-center text-lg-start">
                <a href="{{ path('app_home') }}" class="footer-logo d-inline-block mb-3">
                    {% if site is not null and site.logo is not null %}
                        <img src="{{ asset('documents/medias/' ~ site.logo.fileName) }}" alt="{{ site.name|default('') }}"/>
                    {% else %}
                        <img src="{{ asset('images/BlogWebbeta - blanc.png') }}" alt="Blog&Web"/>
                    {% endif %}
                </a>
                <p class="footer-tagline">{{ site.defaultSeoDescription|default('') }}</p>
            </div>
            <div class="col-lg-4 mb-4 mb-lg-0">
                <h6 class="footer-heading">Horaires & Contact</h6>
                <ul class="nav flex-column">
                    {% if site.phone %}<li class="nav-item"><a href="tel:{{ site.phone }}" class="nav-link">{{ site.phone }}</a></li>{% endif %}
                    {% if site.email %}<li class="nav-item"><a href="mailto:{{ site.email }}" class="nav-link">{{ site.email }}</a></li>{% endif %}
                    {% if site.adress1 %}<li class="nav-item"><span class="nav-link">{{ site.adress1 }}, {{ site.postCode|default('') }} {{ site.town|default('') }}</span></li>{% endif %}
                </ul>
            </div>
            <div class="col-lg-4">
                <h6 class="footer-heading">Navigation</h6>
                <ul class="nav flex-column">
                    <li class="nav-item"><a href="{{ path('app_home') }}" class="nav-link">Accueil</a></li>
                    {% for menu in menus %}
                    <li class="nav-item"><a href="{{ menu|menuLink }}" class="nav-link">{{ menu.name }}</a></li>
                    {% endfor %}
                    <li class="nav-item"><a href="{{ path('app_article_show_all') }}" class="nav-link">Blog</a></li>
                    <li class="nav-item"><a href="{{ path('app_contact') }}" class="nav-link">Contact</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom pt-4 mt-4 text-center">
            <span>&copy; {{ "now"|date("Y") }} {{ site.name|default('') }} &mdash; Tous droits reserves</span>
        </div>
    </div>
</footer>
