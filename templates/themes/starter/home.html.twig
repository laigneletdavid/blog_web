{# ====== HOME — Theme Starter ====== #}
{# Layout: Minimaliste. Texte centre, liste articles en simple liste, rien de superflu #}

{# ====== HERO TEXTE SEUL ====== #}
<section class="start-hero">
    <div class="container">
        <h1 class="start-hero__title">{{ site.name|default('Bienvenue') }}</h1>
        <p class="start-hero__desc">{{ site.defaultSeoDescription|default('') }}</p>
        <div class="start-hero__actions">
            <a href="{{ path('app_contact') }}" class="btn btn-dark">Contact</a>
            <a href="{{ path('app_article_show_all') }}" class="btn btn-outline-dark">Blog</a>
        </div>
    </div>
</section>

{# ====== DERNIERS ARTICLES — liste simple ====== #}
<section class="start-articles">
    <div class="container">
        <h2 class="start-section-title">Derniers articles</h2>
        <div class="start-articles__list">
            {% for article in articles %}
            <a href="{{ path('app_article_show', {slug: article.slug}) }}" class="start-article-item">
                <div class="start-article-item__info">
                    <h3 class="start-article-item__title">{{ article.title }}</h3>
                    <p class="start-article-item__excerpt">{{ article.content|striptags|slice(0, 120) }}...</p>
                </div>
                <span class="start-article-item__date">
                    {% if article.publishedAt %}{{ article.publishedAt|date('d/m/Y') }}{% endif %}
                </span>
            </a>
            {% endfor %}
        </div>
        <div class="text-center mt-4">
            <a href="{{ path('app_article_show_all') }}" class="btn btn-outline-dark btn-sm">Tous les articles &rarr;</a>
        </div>
    </div>
</section>

{# ====== A PROPOS ====== #}
{% if site.aboutImage or site.defaultSeoDescription %}
<section class="start-about">
    <div class="container">
        <div class="row align-items-center g-5">
            {% if site.aboutImage %}
            <div class="col-md-4 text-center">
                <img src="{{ asset('documents/medias/' ~ site.aboutImage.fileName) }}" alt="{{ site.name|default('') }}" class="start-about__img" loading="lazy"/>
            </div>
            {% endif %}
            <div class="col-md-{{ site.aboutImage ? '8' : '12' }}">
                <h2 class="start-section-title">A propos</h2>
                <p class="start-about__text">{{ site.defaultSeoDescription|default('') }}</p>
            </div>
        </div>
    </div>
</section>
{% endif %}
