{# ====== FOOTER — Theme Starter ====== #}
{# Style: Ultra-simple, une ligne #}
<footer class="footer footer--starter">
    <div class="container py-3">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
            <span class="start-footer-copy">&copy; {{ "now"|date("Y") }} {{ site.name|default('') }}</span>
            <nav class="d-flex flex-wrap gap-3">
                {% for menu in footer_nav_menus %}
                    <a href="{{ menu|menuLink }}" class="start-footer-link">{{ menu.name }}</a>
                {% endfor %}
                {% for menu in footer_legal_menus %}
                    <a href="{{ menu|menuLink }}" class="start-footer-link">{{ menu.name }}</a>
                {% endfor %}
            </nav>
        </div>
    </div>
</footer>
