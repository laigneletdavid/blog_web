{# ====== CONTACT — Theme Starter ====== #}
{# Layout: Ultra-simple, formulaire centre, infos en bas #}

<div class="container">
    <nav aria-label="breadcrumb" class="my-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
            <li class="breadcrumb-item active">{{ title_page }}</li>
        </ol>
    </nav>

    <div class="start-contact">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <h1 class="start-contact__title">{{ title_page }}</h1>

                {{ form_start(contactForm) }}
                    {{ form_widget(contactForm) }}
                    <button class="btn btn-dark mt-3" type="submit">Envoyer</button>
                {{ form_end(contactForm) }}

                <div class="start-contact__info mt-5">
                    {% if site.email %}<p><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>{% endif %}
                    {% if site.phone %}<p><a href="tel:{{ site.phone }}">{{ site.phone }}</a></p>{% endif %}
                    {% if site.adress1 %}<p>{{ site.adress1 }}, {{ site.postCode|default('') }} {{ site.town|default('') }}</p>{% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
