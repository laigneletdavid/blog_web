{# ====== HOME — Theme Default ====== #}

{# ====== HERO ====== #}
<section class="hero">
    <div class="container text-center">
        <span class="hero-badge">CMS professionnel</span>
        <h1 class="hero-title">Creez votre site web<br>en toute simplicite</h1>
        <p class="hero-subtitle">{{ text_page }}</p>
        <p class="hero-description">Un CMS francais, simple et performant. Accompagne par un professionnel du web pour lancer et faire vivre votre presence en ligne.</p>
        <div class="hero-actions">
            <a href="{{ path('app_contact') }}" class="btn btn-light btn-lg">Demarrer votre projet</a>
            <a href="{{ path('app_article_show_all') }}" class="btn btn-outline-light btn-lg">Decouvrir le blog</a>
        </div>
        <div class="hero-badges">
            <span class="hero-trust-badge">&#9989; Installation en 30 min</span>
            <span class="hero-trust-badge">&#128274; Securise & RGPD</span>
            <span class="hero-trust-badge">&#127467;&#127479; Heberge en France</span>
        </div>
    </div>
</section>

{# ====== FEATURES ====== #}
<section class="features">
    <div class="container">
        <h2 class="section-title">Tout ce dont vous avez besoin</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <h3 class="feature-title">Editeur visuel</h3>
                <p class="feature-description">Redigez vos articles avec un editeur moderne. Texte, images, videos, code — tout en un.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
                <h3 class="feature-title">Pages & Layouts</h3>
                <p class="feature-description">Creez des pages vitrine avec differents layouts pour presenter vos services et votre activite.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                </div>
                <h3 class="feature-title">Navigation flexible</h3>
                <p class="feature-description">Organisez votre menu par glisser-deposer, avec sous-menus et liens personnalises.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <h3 class="feature-title">SEO integre</h3>
                <p class="feature-description">Meta tags, sitemap XML, Open Graph — votre site est optimise pour les moteurs de recherche.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <h3 class="feature-title">Contact & Notifications</h3>
                <p class="feature-description">Formulaire de contact, commentaires et notifications email pour rester connecte a vos visiteurs.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                </div>
                <h3 class="feature-title">Design personnalisable</h3>
                <p class="feature-description">Couleurs, polices et logo — personnalisez votre site sans toucher au code.</p>
            </div>
        </div>
    </div>
</section>

{# ====== SERVICES (si module actif) ====== #}
{% if services|default([])|length > 0 %}
<section class="default-services py-5">
    <div class="container">
        <h2 class="text-center mb-4" style="font-weight: 700;">Nos services</h2>
        {% include '_partials/_services_grid.html.twig' with { services: services } %}
    </div>
</section>
{% endif %}

{# ====== PRODUITS (si module actif) ====== #}
{% if featuredProducts|default([])|length > 0 %}
    {% include '_partials/_product_featured.html.twig' with { featuredProducts: featuredProducts, site: site|default(null) } %}
{% endif %}

{# ====== ÉVÉNEMENTS (si module actif) ====== #}
{% if upcomingEvents|default([])|length > 0 %}
<section class="home-events py-5">
    <div class="container">
        <h2 class="section-title">Prochains événements</h2>
        <div class="events-grid events-grid--home">
            {% for event in upcomingEvents %}
                {% include '_partials/_event_card.html.twig' with { event: event } %}
            {% endfor %}
        </div>
        <div class="text-center mt-4">
            <a href="{{ path('app_event_index') }}" class="btn btn-outline-primary">Voir tous les événements</a>
        </div>
    </div>
</section>
{% endif %}

{# ====== METRICS ====== #}
<section class="metrics">
    <div class="container">
        <div class="row">
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">30</div>
                <div class="metric-label">minutes d'installation</div>
            </div>
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">100%</div>
                <div class="metric-label">personnalisable</div>
            </div>
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">0</div>
                <div class="metric-label">competence technique requise</div>
            </div>
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">1</div>
                <div class="metric-label">interlocuteur dedie</div>
            </div>
        </div>
    </div>
</section>

{# ====== ARTICLES ====== #}
<section class="py-5">
    <div class="container">
        <h2 class="section-title">Derniers articles</h2>
        <div class="row mb-0 mb-lg-5">
            {% include 'article/article_liste.html.twig' with { articles } %}
        </div>
    </div>
</section>

{# ====== TEAM ====== #}
<section class="py-5" style="background: var(--surface);">
    <div class="container team">
        <div class="d-flex flex-column flex-lg-row align-items-center gap-4">
            <div class="col-12 col-lg-3 team_img d-flex justify-content-center">
                <img src="{{ asset('images/profil.jpg') }}" alt="David Laignelet" class="rounded-circle">
            </div>
            <div class="col-12 col-lg-9 team_text d-flex flex-column justify-content-evenly align-items-center">
                <h4 class="team_name mb-3">David Laignelet</h4>
                <div class="team_text fst-italic">
                    <p>Fort d'une experience de plus de 15 ans dans le commerce, le management et le web, j'ai cree Blog & Web pour rendre internet accessible aux entreprises et particuliers.</p>
                    <p>Blog & Web, c'est un outil a taille humaine. Un interlocuteur unique, une solution cle en main, et un suivi personnalise pour faire vivre votre projet en ligne.</p>
                </div>
            </div>
        </div>
    </div>
</section>

{# ====== CTA FINAL ====== #}
<section class="cta-section">
    <div class="container">
        <h2 class="cta-title">Pret a lancer votre site ?</h2>
        <p class="cta-description">Contactez-nous pour discuter de votre projet. Installation, personnalisation et mise en ligne en quelques jours.</p>
        <a href="{{ path('app_contact') }}" class="btn btn-light btn-lg">Nous contacter</a>
    </div>
</section>
