{# ====== HOME — Theme Moderne ====== #}

{# ====== HERO ====== #}
<section class="hero hero-moderne">
    <div class="container text-center">
        <span class="hero-badge">{{ site.name|default('Blog&Web') }}</span>
        <h1 class="hero-title hero-gradient-text">Creez votre site web<br>du futur, aujourd'hui</h1>
        <p class="hero-subtitle">{{ text_page }}</p>
        <p class="hero-description">{{ site.defaultSeoDescription|default('Un CMS performant et moderne. Design audacieux, experience fluide, technologie de pointe.') }}</p>
        <div class="hero-actions">
            <a href="{{ path('app_contact') }}" class="btn btn-gradient btn-lg">Commencer maintenant</a>
            <a href="{{ path('app_article_show_all') }}" class="btn btn-outline-light btn-lg">Explorer le blog</a>
        </div>
    </div>
</section>

{# ====== FEATURES ====== #}
<section class="features">
    <div class="container">
        <h2 class="section-title text-center">Technologies modernes</h2>
        <div class="features-grid">
            <div class="feature-card glass-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <h3 class="feature-title">Editeur nouvelle generation</h3>
                <p class="feature-description">Un editeur de contenu intuitif et puissant. Creez des pages riches en quelques clics.</p>
            </div>
            <div class="feature-card glass-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <h3 class="feature-title">Performance optimale</h3>
                <p class="feature-description">Temps de chargement ultra-rapide, SEO integre, score Lighthouse maximise.</p>
            </div>
            <div class="feature-card glass-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                </div>
                <h3 class="feature-title">Design adaptatif</h3>
                <p class="feature-description">Responsive sur tous les ecrans. Dark mode natif et animations fluides.</p>
            </div>
            <div class="feature-card glass-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                </div>
                <h3 class="feature-title">Navigation intuitive</h3>
                <p class="feature-description">Menus flexibles, recherche instantanee, experience utilisateur soignee.</p>
            </div>
            <div class="feature-card glass-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <h3 class="feature-title">Engagement visiteurs</h3>
                <p class="feature-description">Commentaires, partage social et notifications pour une communaute active.</p>
            </div>
            <div class="feature-card glass-card">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
                <h3 class="feature-title">Multi-themes</h3>
                <p class="feature-description">Changez de look en un clic. 6 themes professionnels inclus.</p>
            </div>
        </div>
    </div>
</section>

{# ====== METRICS ====== #}
<section class="metrics">
    <div class="container">
        <div class="row">
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">30</div>
                <div class="metric-label">minutes d'installation</div>
            </div>
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">100%</div>
                <div class="metric-label">personnalisable</div>
            </div>
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">6</div>
                <div class="metric-label">themes inclus</div>
            </div>
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">1</div>
                <div class="metric-label">interlocuteur dedie</div>
            </div>
        </div>
    </div>
</section>

{# ====== ARTICLES ====== #}
<section class="py-5">
    <div class="container">
        <h2 class="section-title text-center">Derniers articles</h2>
        <div class="row mb-0 mb-lg-5">
            {% include 'article/article_liste.html.twig' with { articles } %}
        </div>
    </div>
</section>

{# ====== CTA ====== #}
<section class="cta-section">
    <div class="container text-center">
        <h2 class="cta-title">Pret a passer au niveau superieur ?</h2>
        <p class="cta-description">Lancez votre site avec un design qui sort du lot.</p>
        <a href="{{ path('app_contact') }}" class="btn btn-gradient btn-lg">Demarrer maintenant</a>
    </div>
</section>
