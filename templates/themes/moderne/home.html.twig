{# ====== HOME — Theme Moderne ====== #}
{# Layout: Hero gradient avec animation, features grid avec glow, galerie hover, articles cards dark #}

{# ====== HERO GRADIENT ====== #}
<section class="mod-hero">
    <div class="mod-hero__glow"></div>
    <div class="container position-relative">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-7">
                <span class="mod-hero__badge">{{ site.title|default('') }}</span>
                <h1 class="mod-hero__title">{{ site.name|default('Bienvenue') }}</h1>
                <p class="mod-hero__desc">{{ site.defaultSeoDescription|default('') }}</p>
                <div class="mod-hero__actions">
                    <a href="{{ path('app_contact') }}" class="btn mod-btn-gradient btn-lg">Nous contacter</a>
                    <a href="{{ path('app_article_show_all') }}" class="btn btn-outline-light btn-lg">Explorer</a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                {% if site.heroImage %}
                <img src="{{ asset('documents/medias/' ~ site.heroImage.fileName) }}" alt="{{ site.name|default('') }}" class="mod-hero__img" loading="lazy"/>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{# ====== FEATURES ====== #}
<section class="mod-features">
    <div class="container">
        <h2 class="mod-section-title text-center">Ce que nous proposons</h2>
        <div class="row g-4">
            {% for menu in menus[:6] %}
            <div class="col-md-6 col-lg-4">
                <div class="mod-feature-card">
                    <div class="mod-feature-card__glow"></div>
                    <span class="mod-feature-card__number">0{{ loop.index }}</span>
                    <h3 class="mod-feature-card__title">{{ menu.name }}</h3>
                    <p class="mod-feature-card__text">Decouvrez notre expertise {{ menu.name|lower }}.</p>
                    <a href="{{ menu|menuLink }}" class="mod-feature-card__link">Explorer &rarr;</a>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ====== GALERIE ====== #}
{% set gallery = site.getGalleryBySlot('gallery') %}
{% if gallery|length > 0 %}
<section class="mod-gallery">
    <div class="container">
        <h2 class="mod-section-title text-center">Nos realisations</h2>
        <div class="mod-gallery__grid">
            {% for item in gallery[:4] %}
            <div class="mod-gallery__item">
                <img src="{{ asset('documents/medias/' ~ item.media.fileName) }}" alt="{{ item.title|default('') }}" loading="lazy"/>
                <div class="mod-gallery__overlay">
                    <span>{{ item.title|default('') }}</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ====== STATS ====== #}
<section class="mod-stats">
    <div class="container">
        <div class="row text-center">
            <div class="col-6 col-lg-3 mod-stat">
                <div class="mod-stat__value">30</div>
                <div class="mod-stat__label">min d'installation</div>
            </div>
            <div class="col-6 col-lg-3 mod-stat">
                <div class="mod-stat__value">100%</div>
                <div class="mod-stat__label">personnalisable</div>
            </div>
            <div class="col-6 col-lg-3 mod-stat">
                <div class="mod-stat__value">0</div>
                <div class="mod-stat__label">code requis</div>
            </div>
            <div class="col-6 col-lg-3 mod-stat">
                <div class="mod-stat__value">1</div>
                <div class="mod-stat__label">contact dedie</div>
            </div>
        </div>
    </div>
</section>

{# ====== ARTICLES ====== #}
<section class="mod-articles">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mod-section-title mb-0">Blog</h2>
            <a href="{{ path('app_article_show_all') }}" class="btn btn-outline-light btn-sm">Tout voir</a>
        </div>
        <div class="row">
            {% include 'article/article_liste.html.twig' with { articles } %}
        </div>
    </div>
</section>

{# ====== CTA ====== #}
<section class="mod-cta">
    <div class="container text-center">
        <h2 class="mod-cta__title">Pret a demarrer ?</h2>
        <p class="mod-cta__desc">Discutons de votre projet.</p>
        <a href="{{ path('app_contact') }}" class="btn mod-btn-gradient btn-lg">Nous contacter</a>
    </div>
</section>
