{# ====== HEADER — Theme Moderne ====== #}
{# Style: Dark, transparent, glassmorphism #}
<header class="header header--moderne">
    {% if is_granted('ROLE_CORRECTOR') %}
    <div class="admin-bar">
        <div class="container d-flex align-items-center gap-2 py-1">
            <img src="{{ asset('images/logo xlight- b&w-50px.png') }}" alt="Admin" style="height: 20px;"/>
            <a href="{{ path('admin') }}">Administration</a>
        </div>
    </div>
    {% endif %}

    <div class="header-main desk">
        <div class="container d-flex align-items-center justify-content-between">
            <a href="{{ path('app_home') }}" class="header-logo">
                {% if site is not null and site.logo is not null %}
                    <img src="{{ asset('documents/medias/' ~ site.logo.fileName) }}" alt="{{ site.name|default('') }}"/>
                {% else %}
                    <img src="{{ asset('images/BlogWebbeta-h150.png') }}" alt="Blog&Web"/>
                {% endif %}
            </a>

            <nav class="header-nav d-flex align-items-center gap-1">
                {% for menu in menus %}
                    {% if menu.children|length > 0 %}
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle" href="{{ menu|menuLink }}" data-bs-toggle="dropdown">{{ menu.name }}</a>
                            <ul class="dropdown-menu">
                                {% for child in menu.children %}
                                    {% if child.isVisible %}
                                        <li><a class="dropdown-item" href="{{ child|menuLink }}">{{ child.name }}</a></li>
                                    {% endif %}
                                {% endfor %}
                            </ul>
                        </div>
                    {% else %}
                        <a href="{{ menu|menuLink }}" class="nav-link">{{ menu.name }}</a>
                    {% endif %}
                {% endfor %}
                <a href="{{ path('app_article_show_all') }}" class="nav-link">Blog</a>
            </nav>

            <div class="header-actions d-flex align-items-center gap-2">
                <div class="header-search dropdown" data-controller="search">
                    <form class="d-flex align-items-center gap-2" action="{{ path('app_search_results') }}" method="get" data-search-target="form" data-api-url="{{ path('app_search') }}" data-action="search#doSearch:prevent">
                        <input type="search" name="q" class="form-control form-control-sm search-input" placeholder="Rechercher..." aria-label="Rechercher" data-search-target="q" autocomplete="off">
                        <button class="btn btn-sm btn-outline-light" type="submit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/></svg>
                        </button>
                    </form>
                    <div class="dropdown-menu" data-search-target="results"></div>
                </div>
                <a href="{{ path('app_contact') }}" class="btn mod-btn-gradient btn-sm">Contact</a>
            </div>
        </div>
    </div>

    <div class="header-mobile smart">
        <div class="container d-flex align-items-center justify-content-between py-2">
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-label="Menu" style="color: var(--text);">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/></svg>
            </button>
            <a href="{{ path('app_home') }}" class="header-logo">
                {% if site is not null and site.logo is not null %}
                    <img src="{{ asset('documents/medias/' ~ site.logo.fileName) }}" alt="{{ site.name|default('') }}"/>
                {% else %}
                    <img src="{{ asset('images/BlogWebbeta-h150.png') }}" alt="Blog&Web"/>
                {% endif %}
            </a>
            <div></div>
        </div>
        <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasNavbar" style="background: var(--surface); color: var(--text);">
            <div class="offcanvas-header">
                <span class="fw-bold">{{ site.name|default('Menu') }}</span>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Fermer"></button>
            </div>
            <div class="offcanvas-body">
                <div class="header-search dropdown mb-4" data-controller="search">
                    <form class="d-flex gap-2" action="{{ path('app_search_results') }}" method="get" data-search-target="form" data-api-url="{{ path('app_search') }}" data-action="search#doSearch:prevent">
                        <input type="search" name="q" class="form-control" placeholder="Rechercher..." aria-label="Rechercher" data-search-target="q" autocomplete="off" style="background: var(--surface); color: var(--text); border-color: var(--border);">
                        <button class="btn btn-outline-light" type="submit">Chercher</button>
                    </form>
                    <div class="dropdown-menu" data-search-target="results"></div>
                </div>
                <ul class="navbar-nav mb-4">
                    <li class="nav-item"><a href="{{ path('app_home') }}" class="nav-link">Accueil</a></li>
                    {% for menu in menus %}
                        <li class="nav-item"><a href="{{ menu|menuLink }}" class="nav-link">{{ menu.name }}</a></li>
                    {% endfor %}
                    <li class="nav-item"><a href="{{ path('app_article_show_all') }}" class="nav-link">Blog</a></li>
                    <li class="nav-item"><a href="{{ path('app_contact') }}" class="nav-link">Contact</a></li>
                </ul>
            </div>
        </div>
    </div>
</header>
