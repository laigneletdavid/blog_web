{# ====== HEADER — Theme Corporate ====== #}
<header class="header header-corporate">
    {# Admin bar #}
    {% if is_granted('ROLE_CORRECTOR') %}
    <div class="admin-bar">
        <div class="container d-flex align-items-center gap-2 py-1">
            <img src="{{ asset('images/logo xlight- b&w-50px.png') }}" alt="Admin" style="height: 20px;"/>
            <a href="{{ path('admin') }}">Administration</a>
        </div>
    </div>
    {% endif %}

    {# Top info bar #}
    <div class="corporate-topbar d-none d-lg-block">
        <div class="container d-flex align-items-center justify-content-between py-1">
            <div class="d-flex align-items-center gap-3">
                {% if site.phone is not null %}
                <span class="topbar-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328zM1.884.511a1.745 1.745 0 0 1 2.612.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511z"/></svg>
                    {{ site.phone }}
                </span>
                {% endif %}
                {% if site.email is not null %}
                <span class="topbar-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4Zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2Zm13 2.383-4.708 2.825L15 11.105V5.383Zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741ZM1 11.105l4.708-2.897L1 5.383v5.722Z"/></svg>
                    {{ site.email }}
                </span>
                {% endif %}
            </div>
            <div class="d-flex align-items-center gap-2">
                {% if app.user %}
                    <a class="topbar-link" href="{{ path('app_user_show', { 'id': app.user.id}) }}">Mon compte</a>
                    <a class="topbar-link" href="{{ path('app_logout')}}">Deconnexion</a>
                {% else %}
                    <a class="topbar-link" href="{{ path('app_login')}}">Connexion</a>
                    <a class="topbar-link" href="{{ path('app_register')}}">Inscription</a>
                {% endif %}
            </div>
        </div>
    </div>

    {# Desktop header #}
    <div class="header-main desk">
        <div class="container d-flex align-items-center justify-content-between">
            <a href="{{ path('app_home') }}" class="header-logo">
                {% if site is not null and site.logo is not null %}
                    <img src="{{ asset('documents/medias/' ~ site.logo.fileName) }}" alt="{{ site.name|default('Blog&Web') }}"/>
                {% else %}
                    <img src="{{ asset('images/BlogWebbeta-h150.png') }}" alt="Blog&Web"/>
                {% endif %}
            </a>

            <nav class="header-nav d-flex align-items-center gap-1">
                <a href="{{ path('app_home') }}" class="nav-link">Accueil</a>
                {% for menu in menus %}
                    {% if menu.children|length > 0 %}
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle" href="{{ menu|menuLink }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">{{ menu.name }}</a>
                            <ul class="dropdown-menu">
                                {% for child in menu.children %}
                                    {% if child.isVisible %}
                                        <li><a class="dropdown-item" href="{{ child|menuLink }}">{{ child.name }}</a></li>
                                    {% endif %}
                                {% endfor %}
                            </ul>
                        </div>
                    {% else %}
                        <a href="{{ menu|menuLink }}" class="nav-link">{{ menu.name }}</a>
                    {% endif %}
                {% endfor %}
                <a href="{{ path('app_contact') }}" class="nav-link">Contact</a>
            </nav>

            <div class="header-actions d-flex align-items-center gap-2">
                <div class="header-search dropdown" data-controller="search">
                    <form class="d-flex align-items-center gap-2" action="{{ path('app_search') }}" method="get" data-search-target="form" data-action="search#doSearch:prevent">
                        <input type="search" name="q" class="form-control form-control-sm search-input" placeholder="Rechercher..." aria-label="Search" data-search-target="q" autocomplete="off">
                        <button class="btn btn-sm btn-outline-primary" type="submit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/></svg>
                        </button>
                    </form>
                    <div class="dropdown-menu" data-search-target="results"><a class="dropdown-item" href="#">Contenu</a></div>
                </div>
                <a href="{{ path('app_contact') }}" class="btn btn-sm btn-outline-primary">Nous contacter</a>
            </div>
        </div>
    </div>

    {# Mobile header #}
    <div class="header-mobile smart">
        <div class="container d-flex align-items-center justify-content-between py-2">
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar" aria-label="Toggle navigation">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/></svg>
            </button>
            <a href="{{ path('app_home') }}" class="header-logo">
                {% if site is not null and site.logo is not null %}
                    <img src="{{ asset('documents/medias/' ~ site.logo.fileName) }}" alt="{{ site.name|default('Blog&Web') }}"/>
                {% else %}
                    <img src="{{ asset('images/BlogWebbeta-h150.png') }}" alt="Blog&Web"/>
                {% endif %}
            </a>
            <div></div>
        </div>
        <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasNavbar">
            <div class="offcanvas-header">
                <span class="fw-bold">{{ site.name|default('Blog&Web') }}</span>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body">
                <ul class="navbar-nav flex-grow-1 mb-4">
                    <li class="nav-item"><a href="{{ path('app_home') }}" class="nav-link">Accueil</a></li>
                    {% for menu in menus %}
                        {% if menu.children|length > 0 %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="{{ menu|menuLink }}" role="button" data-bs-toggle="dropdown">{{ menu.name }}</a>
                                <ul class="dropdown-menu">
                                    {% for child in menu.children %}{% if child.isVisible %}<li><a class="dropdown-item" href="{{ child|menuLink }}">{{ child.name }}</a></li>{% endif %}{% endfor %}
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item"><a href="{{ menu|menuLink }}" class="nav-link">{{ menu.name }}</a></li>
                        {% endif %}
                    {% endfor %}
                    <li class="nav-item"><a href="{{ path('app_contact') }}" class="nav-link">Contact</a></li>
                </ul>
                <div class="d-grid gap-2">
                    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                        <a href="{{ path('app_user_show', {'id': app.user.id}) }}" class="btn btn-primary">Mon profil</a>
                        <a href="{{ path('app_logout') }}" class="btn btn-outline-secondary">Se deconnecter</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-primary">Se connecter</a>
                        <a href="{{ path('app_register') }}" class="btn btn-outline-primary">Creer un compte</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</header>
