{# ====== HOME — Theme Corporate ====== #}

{# ====== HERO ====== #}
<section class="hero hero-corporate">
    <div class="container">
        <div class="row align-items-center py-5">
            <div class="col-lg-7">
                <h1 class="hero-title">{{ site.name|default('Votre entreprise') }}</h1>
                <p class="hero-subtitle">{{ site.defaultSeoDescription|default('Solutions professionnelles adaptees a vos besoins. Un accompagnement sur mesure pour developper votre activite en ligne.') }}</p>
                <div class="hero-actions mt-4">
                    <a href="{{ path('app_contact') }}" class="btn btn-primary btn-lg">Demander un devis</a>
                    <a href="{{ path('app_article_show_all') }}" class="btn btn-outline-primary btn-lg ms-2">Nos actualites</a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center">
                {% if site is not null and site.logo is not null %}
                    <img src="{{ asset('documents/medias/' ~ site.logo.fileName) }}" alt="{{ site.name }}" class="hero-corporate-logo">
                {% endif %}
            </div>
        </div>
    </div>
</section>

{# ====== SERVICES ====== #}
<section class="py-5">
    <div class="container">
        <h2 class="section-title text-center mb-5">Nos services</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 corporate-card">
                    <div class="card-body text-center p-4">
                        <div class="feature-icon mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        </div>
                        <h3 class="h5">Expertise</h3>
                        <p class="text-muted">Un accompagnement professionnel pour chaque etape de votre projet digital.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 corporate-card">
                    <div class="card-body text-center p-4">
                        <div class="feature-icon mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                        </div>
                        <h3 class="h5">Solution cle en main</h3>
                        <p class="text-muted">De la conception a la mise en ligne, nous gerons l'ensemble de votre presence web.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 corporate-card">
                    <div class="card-body text-center p-4">
                        <div class="feature-icon mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                        </div>
                        <h3 class="h5">Suivi personnalise</h3>
                        <p class="text-muted">Un interlocuteur unique et reactif pour repondre a toutes vos questions.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{# ====== METRICS ====== #}
<section class="metrics">
    <div class="container">
        <div class="row">
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">30</div>
                <div class="metric-label">minutes d'installation</div>
            </div>
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">100%</div>
                <div class="metric-label">personnalisable</div>
            </div>
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">0</div>
                <div class="metric-label">competence technique requise</div>
            </div>
            <div class="col-6 col-md-3 metric-item">
                <div class="metric-value">1</div>
                <div class="metric-label">interlocuteur dedie</div>
            </div>
        </div>
    </div>
</section>

{# ====== ARTICLES ====== #}
<section class="py-5">
    <div class="container">
        <h2 class="section-title text-center">Actualites</h2>
        <div class="row mb-0 mb-lg-5">
            {% include 'article/article_liste.html.twig' with { articles } %}
        </div>
        <div class="text-center mt-3">
            <a href="{{ path('app_article_show_all') }}" class="btn btn-outline-primary">Voir toutes les actualites</a>
        </div>
    </div>
</section>

{# ====== CTA ====== #}
<section class="cta-section">
    <div class="container text-center">
        <h2 class="cta-title">Pret a developper votre presence en ligne ?</h2>
        <p class="cta-description">Contactez-nous pour une etude personnalisee de votre projet.</p>
        <a href="{{ path('app_contact') }}" class="btn btn-light btn-lg">Nous contacter</a>
    </div>
</section>
