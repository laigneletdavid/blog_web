{% extends 'base.html.twig' %}

{% block jsonld %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ (article.seoTitle ?? article.title)|json_encode|raw }},
    "datePublished": "{{ (article.publishedAt ?? article.createdAt)|date('c') }}",
    "dateModified": "{{ (article.updatedAt ?? article.createdAt)|date('c') }}",
    {% if article.featuredMedia %}
    "image": "{{ absolute_url(asset('documents/medias/' ~ article.featuredMedia.fileName)) }}",
    {% endif %}
    "description": {{ (article.seoDescription ?? article.featuredText ?? '')|json_encode|raw }},
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ app.request.uri }}"
    }
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "{{ absolute_url(path('app_home')) }}"},
        {"@type": "ListItem", "position": 2, "name": "Blog", "item": "{{ absolute_url(path('app_article_show_all')) }}"},
        {"@type": "ListItem", "position": 3, "name": {{ article.title|json_encode|raw }}}
    ]
}
</script>
{% endblock %}

{% block body %}

{# --- Breadcrumbs --- #}
<div class="container">
    <nav aria-label="breadcrumb" class="mt-3 mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_article_show_all') }}">Blog</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ article.title }}</li>
        </ol>
    </nav>
</div>

{# --- Featured image hero --- #}
{% if article.featuredMedia %}
<div class="container">
    <div class="article-hero">
        {{ responsive_img(article.featuredMedia, '(max-width: 768px) 100vw, 900px', 'article-hero__img') }}
    </div>
</div>
{% endif %}

<div class="container">
    <div class="row">
        {# ====== Barre partage sticky (desktop gauche) ====== #}
        <div class="col-lg-1 d-none d-lg-block">
            {% set articleUrl = url('app_article_show', { slug: article.slug }) %}
            {% set articleTitle = article.title|url_encode %}
            <div class="share-sticky">
                <a href="https://www.facebook.com/sharer/sharer.php?u={{ articleUrl }}" target="_blank" rel="noopener" class="share-sticky__btn share-sticky__btn--facebook" title="Partager sur Facebook">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://twitter.com/intent/tweet?url={{ articleUrl }}&text={{ articleTitle }}" target="_blank" rel="noopener" class="share-sticky__btn share-sticky__btn--twitter" title="Partager sur Twitter">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ articleUrl }}" target="_blank" rel="noopener" class="share-sticky__btn share-sticky__btn--linkedin" title="Partager sur LinkedIn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <button class="share-sticky__btn share-sticky__btn--copy" onclick="navigator.clipboard.writeText('{{ articleUrl }}');this.classList.add('copied');setTimeout(()=>this.classList.remove('copied'),2000)" title="Copier le lien">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                </button>
            </div>
        </div>

        {# ====== Contenu principal ====== #}
        <div class="col-lg-7">
            <article class="article-detail">
                {# --- Meta header --- #}
                <div class="article-detail__meta">
                    {% for cat in article.categories %}
                        <a href="{{ path('app_article_show_all', { categorie: cat.slug }) }}" class="article-detail__badge">{{ cat.name }}</a>
                    {% endfor %}
                    <time datetime="{{ article.createdAt|date('Y-m-d') }}">{{ article.createdAt|date('d M Y') }}</time>
                    <span class="article-detail__dot"></span>
                    <span>{{ article.content|readingTime }} min de lecture</span>
                </div>

                {# --- Titre --- #}
                <h1 class="article-detail__title">{{ article.title }}</h1>

                {% if article.featuredText %}
                    <p class="article-detail__lead">{{ article.featuredText }}</p>
                {% endif %}

                {# --- Contenu (with TOC anchor ids) --- #}
                <div class="article-detail__content">{{ article.content|toc_anchors|raw }}</div>

                {# --- Tags --- #}
                {% if article.tag|length > 0 %}
                <div class="article-detail__tags">
                    {% for tag in article.tag %}
                        <a href="{{ path('app_tag_show', { slug: tag.slug }) }}" class="tag-pill">{{ tag.name }}</a>
                    {% endfor %}
                </div>
                {% endif %}

                {# --- Partage mobile (barre fixe bas) --- #}
                <div class="share-mobile d-lg-none">
                    {% set articleUrl = url('app_article_show', { slug: article.slug }) %}
                    {% set articleTitle = article.title|url_encode %}
                    <a href="https://www.facebook.com/sharer/sharer.php?u={{ articleUrl }}" target="_blank" rel="noopener" class="share-mobile__btn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                    <a href="https://twitter.com/intent/tweet?url={{ articleUrl }}&text={{ articleTitle }}" target="_blank" rel="noopener" class="share-mobile__btn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ articleUrl }}" target="_blank" rel="noopener" class="share-mobile__btn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                    <button class="share-mobile__btn" onclick="navigator.clipboard.writeText('{{ articleUrl }}');this.classList.add('copied');setTimeout(()=>this.classList.remove('copied'),2000)">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    </button>
                </div>

                {# --- Bloc auteur --- #}
                {% if article.comments is defined %}
                    {% set author = article.comments|length > 0 ? null : null %}
                {% endif %}
                <div class="author-card">
                    <div class="author-card__avatar">
                        {% if app.user and app.user.avatar %}
                            <img src="{{ asset('documents/medias/' ~ app.user.avatar.fileName) }}" alt="" class="author-card__img">
                        {% else %}
                            <div class="author-card__placeholder">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </div>
                        {% endif %}
                    </div>
                    <div class="author-card__info">
                        <p class="author-card__name">Blog</p>
                        <p class="author-card__bio">Retrouvez tous nos articles et actualit&eacute;s sur notre blog.</p>
                    </div>
                </div>
            </article>

            {# ====== Commentaires ====== #}
            <section class="article-comments">
                <h3 class="article-comments__title">
                    {{ article.comments|length }} commentaire{{ article.comments|length > 1 ? 's' : '' }}
                </h3>

                {% if is_granted('ROLE_USER') %}
                    <div class="article-comments__form">
                        {{ form_start(commentForm) }}
                        {{ form_widget(commentForm) }}
                        <button type="submit" class="btn btn-primary btn-sm mt-2">Envoyer</button>
                        {{ form_end(commentForm) }}
                    </div>
                {% else %}
                    <p class="text-muted mb-4"><a href="{{ path('app_login') }}">Connectez-vous</a> pour laisser un commentaire.</p>
                {% endif %}

                <div class="article-comments__list">
                    {% for comment in article.comments %}
                        <div class="comment-card">
                            <div class="comment-card__header">
                                <strong class="comment-card__author">{{ comment.user.displayName }}</strong>
                                <time class="comment-card__date">{{ comment.createdAt|date('d/m/Y') }} à {{ comment.createdAt|date('H:i') }}</time>
                            </div>
                            <p class="comment-card__body">{{ comment.content }}</p>
                        </div>
                    {% endfor %}
                </div>
            </section>

            {# ====== Articles connexes ====== #}
            {% if relatedArticles is defined and relatedArticles|length > 0 %}
                <section class="article-related">
                    <h3 class="article-related__title">Articles similaires</h3>
                    <div class="blog-grid blog-grid--3col">
                        {% for article in relatedArticles %}
                            {% include 'article/item.html.twig' %}
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
        </div>

        {# ====== Sidebar ====== #}
        <div class="col-lg-4">
            <aside class="blog-sidebar">
                {% include 'widgets/toc.html.twig' %}
                {% include 'widgets/subscribe.html.twig' %}
                {% include 'widgets/tag_cloud.html.twig' %}
                {% include 'widgets/categories.html.twig' %}
                {% include 'widgets/last_article.html.twig' %}
                {% include 'widgets/archives.html.twig' %}
            </aside>
        </div>
    </div>
</div>
{% endblock %}
