{% extends 'base.html.twig' %}

{% block jsonld %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ (article.seoTitle ?? article.title)|json_encode|raw }},
    "datePublished": "{{ (article.publishedAt ?? article.createdAt)|date('c') }}",
    "dateModified": "{{ (article.updatedAt ?? article.createdAt)|date('c') }}",
    {% if article.featuredMedia %}
    "image": "{{ absolute_url(asset('documents/medias/' ~ article.featuredMedia.fileName)) }}",
    {% endif %}
    "description": {{ (article.seoDescription ?? article.featuredText ?? '')|json_encode|raw }},
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ app.request.uri }}"
    }
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "{{ absolute_url(path('app_home')) }}"},
        {"@type": "ListItem", "position": 2, "name": "Blog", "item": "{{ absolute_url(path('app_article_show_all')) }}"},
        {"@type": "ListItem", "position": 3, "name": {{ article.title|json_encode|raw }}}
    ]
}
</script>
{% endblock %}

{% block body %}

    <div class="container">
        <div class="breadcrum mb-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_article_show_all') }}">Blog</a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{ article.title }}</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="container">
        <div class="d-flex flex-column-reverse flex-lg-row">
            <div class="col-lg-4">
                <div class="widget d-flex flex-column position-sticky" style="top: 1rem;">
                    {% include 'widgets/subscribe.html.twig' %}
                    {% include 'widgets/categories.html.twig' %}
                    {% include 'widgets/last_article.html.twig' %}
                    {% include 'widgets/archives.html.twig' %}
                </div>
            </div>
            <div class="col-lg-8">

                <article class="article_content d-flex flex-column ps-2">
                    <div class="title_article_groupe d-flex flex-column flex-lg-row justify-content-between mb-lg-5 mb-3">
                        <div class="article_title d-flex flex-column">
                            <h1 class="title-one">{{ article.title }}</h1>
                            {% if article.featuredText %}
                                <h2 class="title-two">{{ article.featuredText }}</h2>
                            {% endif %}
                        </div>
                        <div class="article_data d-flex flex-row flex-lg-column justify-content-between align-items-lg-end mt-3 mt-lg-0">
                            {% for cat in article.categories %}
                                <strong class="d-inline-block ms-3" style="color: {{ cat.color }};">{{ cat.name }}</strong>
                            {% endfor %}
                            <div class="d-flex flex-column align-items-lg-end">
                                <p class="date mb-1">{{ article.createdAt|date('d/m/Y') }}</p>
                                <span class="reading-time"><i class="fas fa-clock"></i> {{ article.content|readingTime }} min de lecture</span>
                            </div>
                        </div>
                    </div>
                    <div class="img_article">
                        {% if article.featuredMedia %}
                            {{ responsive_img(article.featuredMedia, '(max-width: 768px) 100vw, 800px') }}
                        {% endif %}
                    </div>
                    <div class="content mt-5 pb-5">{{ article.content|raw }}</div>

                    {# --- Boutons de partage --- #}
                    <div class="share-buttons">
                        {% set articleUrl = url('app_article_show', { slug: article.slug }) %}
                        {% set articleTitle = article.title|url_encode %}
                        <a href="https://www.facebook.com/sharer/sharer.php?u={{ articleUrl }}" target="_blank" rel="noopener" class="share-btn share-facebook">
                            <i class="fab fa-facebook-f"></i> Facebook
                        </a>
                        <a href="https://twitter.com/intent/tweet?url={{ articleUrl }}&text={{ articleTitle }}" target="_blank" rel="noopener" class="share-btn share-twitter">
                            <i class="fab fa-twitter"></i> Twitter
                        </a>
                        <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ articleUrl }}" target="_blank" rel="noopener" class="share-btn share-linkedin">
                            <i class="fab fa-linkedin-in"></i> LinkedIn
                        </a>
                        <button class="share-btn share-copy" onclick="navigator.clipboard.writeText('{{ articleUrl }}');this.innerHTML='<i class=\'fas fa-check\'></i> Copie !'">
                            <i class="fas fa-link"></i> Copier le lien
                        </button>
                    </div>
                </article>

                {# --- Commentaires (visibles directement, sans accordion) --- #}
                <div class="article_comment d-flex flex-column p-3">
                    <h3 class="comment_title mb-4">
                        <span class="comment_count title-one">{{ article.comments|length }} commentaire(s)</span>
                    </h3>

                    {% if is_granted('ROLE_USER') %}
                        <div class="comment_area mb-4 p-3" style="background: #f8f9fa; border-radius: 0.5rem;">
                            <h4 class="mb-3" style="font-size: 1rem;">Ecrire un commentaire</h4>
                            {{ form_start(commentForm) }}
                            {{ form_widget(commentForm) }}
                            <input type="submit" class="btn-font btn btn-small btn-primary mt-2" value="Envoyer">
                            {{ form_end(commentForm) }}
                        </div>
                    {% else %}
                        <p class="text-muted mb-4"><a href="{{ path('app_login') }}">Connectez-vous</a> pour laisser un commentaire.</p>
                    {% endif %}

                    <div class="comment-list">
                        {% for comment in article.comments %}
                            {% include 'comment/index.html.twig' with { comment: comment } %}
                        {% endfor %}
                    </div>
                </div>

                {# --- Articles connexes --- #}
                {% if relatedArticles is defined and relatedArticles|length > 0 %}
                    <div class="related-articles">
                        <h3>Articles similaires</h3>
                        <div class="related-grid">
                            {% for related in relatedArticles %}
                                <a href="{{ path('app_article_show', { slug: related.slug }) }}" class="related-card">
                                    {% if related.featuredMedia %}
                                        {{ responsive_img(related.featuredMedia, '(max-width: 768px) 100vw, 300px', '', related.title) }}
                                    {% endif %}
                                    <div class="related-card-body">
                                        <h4>{{ related.title }}</h4>
                                        <span class="related-date">{{ related.createdAt|date('d/m/Y') }}</span>
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

            </div>
        </div>
    </div>
{% endblock %}
