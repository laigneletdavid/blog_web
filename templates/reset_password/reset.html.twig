{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
<div class="container">
    <div class="security mb-5">
        <h1 class="title_form mb-3">Nouveau mot de passe</h1>

        {{ form_start(form) }}
            {{ form_row(form.password, { label: 'Nouveau mot de passe' }) }}
            <button class="btn btn-primary" type="submit">Changer le mot de passe</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
