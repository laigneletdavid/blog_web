<div class="p-4 widget_article">
    <h4 class="fst-italic">Dernier article</h4>
    {% if widget_article %}
        <div class="d-flex felx-row">
            <div class="widget_article_img">
                {% if widget_article.featuredMedia %}
                    <img src="{{ asset('documents/medias/' ~ widget_article.featuredMedia.fileName) }}" alt="{{ widget_article.featuredMedia.name }}"/>
                {% endif %}
            </div>
            <div class="ps-3 d-flex flex-column justify-content-evenly">
                <h5 class="mb-0">{{ widget_article.title }}</h5>
                <div class="categories d-flex flex-row">
                    {% for cat in widget_article.categories %}
                        <strong class="d-inline-block mb-2 me-3" style="color: var(--primary);">{{ cat.name }}</strong>
                    {% endfor %}
                </div>
                <div class="mb-1 text-body-secondary">{{ widget_article.createdAt|date('d/m/Y') }}</div>
            </div>
        </div>
        <div class="d-flex flex-column pt-3">
            <p class="card-text pb-3">{{ widget_article.featuredText }}</p>
            <a href="{{ path('app_article_show', { 'slug': widget_article.slug}) }}" class="btn-font btn btn-primary">Voir +</a>
        </div>
    {% else %}
        <p class="text-muted">Aucun article pour le moment.</p>
    {% endif %}
</div>
