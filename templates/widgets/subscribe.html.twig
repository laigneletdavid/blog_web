<div class="p-4 widget_register">
    <h4>Restez informes</h4>
    {% if is_granted('ROLE_USER') %}
        <p>Gerez vos preferences de notification depuis votre profil.</p>
        <div class="d-flex justify-content-center p-3">
            <a class="btn-font btn btn-outline-primary btn-sm shadow-sm" href="{{ path('app_user_info') }}">
                <i class="fas fa-bell"></i> Mes preferences
            </a>
        </div>
    {% else %}
        <p>Recevez directement tous les articles et restez informes de toutes nos actualites.</p>
        <div class="d-flex justify-content-center p-3">
            <a class="btn-font btn btn-primary shadow-sm" href="{{ path('app_register') }}"><span>Creer un compte</span></a>
        </div>
    {% endif %}
</div>
